prefix_rule(
  pattern = ["git", ["pull", "commit", "add", "status", "diff", "checkout", "fetch", "branch", "stash", "rebase", "switch", "restore", "reset"]],
  decision = "allow",
  match = [["git", "pull"], ["git", "checkout", "-b", "foo/bar"]],
  not_match = [["git", "push"]]
)
prefix_rule(
  pattern = ["git", "push"],
  decision = "forbidden",
  match = [["git", "push"], ["git", "push", "--force"]],
  not_match = [["git", "status"]]
)
prefix_rule(pattern=["gh"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "GIT_EDITOR=true git rebase --continue"], decision="allow")
